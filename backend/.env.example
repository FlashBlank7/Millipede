# Database
DATABASE_URL=postgresql+asyncpg://millipede:millipede@localhost:5432/millipede
DATABASE_URL_SYNC=postgresql://millipede:millipede@localhost:5432/millipede

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Object Storage (MinIO)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=millipede
STORAGE_SECRET_KEY=millipede123
STORAGE_BUCKET=millipede
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# Auth
SECRET_KEY=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM — 填其中任意一个即可，DEFAULT_LLM_MODEL 决定使用哪个
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# DeepSeek (https://platform.deepseek.com)
# DEFAULT_LLM_MODEL=deepseek/deepseek-chat
DEEPSEEK_API_KEY=sk-cdd22478d7044b13a735207687d227f6

# 豆包 / 火山引擎 (https://console.volcengine.com/ark)
# DEFAULT_LLM_MODEL=volcengine/doubao-pro-32k
# DOUBAO_MODEL_ID 是火山方舟"接入点 ID"，形如 ep-xxxxxxxxx-xxxxx
VOLCENGINE_API_KEY=
DOUBAO_MODEL_ID=

# 千问 / 阿里云 DashScope (https://dashscope.aliyun.com)
# DEFAULT_LLM_MODEL=openai/qwen-max   (通过 DashScope 的 OpenAI 兼容层)
DASHSCOPE_API_KEY=

DEFAULT_LLM_MODEL=deepseek/deepseek-chat

# Docker Sandbox
SANDBOX_IMAGE=millipede-sandbox:latest
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_CPU_LIMIT=1.0
SANDBOX_NETWORK=none

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
